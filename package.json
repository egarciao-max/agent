{
  "name": "openclaw-cloud-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "bridge": "node local-bridge/server.mjs",
    "bridge:task": "powershell -ExecutionPolicy Bypass -File .\\local-bridge\\install-task.ps1",
    "bridge:startup": "powershell -ExecutionPolicy Bypass -File .\\local-bridge\\install-startup.ps1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260407.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.13.2"
  }
}
